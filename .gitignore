# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/

# Testing / linting
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Environment
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Data layout:
# - raw/ stays untracked (source pools; regenerable via build_* scripts).
# - interim/: track the frozen 200-item base set used to assemble trials;
#   leave other interim artifacts untracked.
# - curated/{version}/: track DATASET_CARD.md + manifest.json only.
#   Trial JSON dumps under trials/ are regenerable and stay untracked
#   (keeps PRs reviewable). See data/README.md for the regen command.
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
!data/interim/base_items_200.json
!data/interim/amps_items_100.json
!data/interim/medquad_items_100.json
data/curated/*/trials/

# Experiment outputs (not committed during scaffolding)
results/*
!results/.gitkeep
!results/README.md
