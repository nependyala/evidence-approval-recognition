# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/

# Testing / linting
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Environment
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Data: raw/interim are regenerable build artifacts (source pools, normalized
# base items) and stay untracked. data/curated/ holds frozen dataset versions
# and IS tracked once a version has been validated and frozen (see
# docs/curation_protocol.md step 12).
data/raw/*
data/interim/*
!data/raw/.gitkeep
!data/interim/.gitkeep

# Experiment outputs (not committed during scaffolding)
results/*
!results/.gitkeep
!results/README.md
